# Copy to `.env.local` for local development (`.env` / `.env.local` are gitignored).

# Better Auth (anonymous users) — Postgres required.
DATABASE_URL=postgresql://kickaway:kickaway@127.0.0.1:5433/kickaway
BETTER_AUTH_SECRET=dev-local-better-auth-secret-min-32-chars
BETTER_AUTH_URL=http://localhost:3000

# Server-side Kick chat collector (Redis + collector process).
REDIS_URL=redis://127.0.0.1:6379
# Local dev only: run the collector inside Next.js (`npm run dev:stack`).
# On Coolify, deploy Dockerfile.collector as a separate service and leave this unset on the web app.
COLLECTOR_MODE=embedded

# Version skew protection — poll interval in seconds (default 60).
NEXT_PUBLIC_VERSION_POLL_INTERVAL_SECONDS=60

# Enable mock participant seeding when a giveaway enters collecting phase.
NEXT_PUBLIC_DEV_MODE=false

# Number of synthetic chat entrants to add (uses the same eligibility pipeline as live Kick).
NEXT_PUBLIC_DEV_MOCK_ENTRANT_COUNT=300

# OpenPanel analytics (self-hosted). Client-side tracking is proxied via /api/kickaway/session.
NEXT_PUBLIC_OPENPANEL_CLIENT_ID=
OPENPANEL_CLIENT_SECRET=
# Self-hosted API URL — include the /api path suffix.
OPENPANEL_API_URL=https://opapi-jcc0ckwk4c00g04sgoo08gkc.botox.boo/api
